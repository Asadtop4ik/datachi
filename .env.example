# ── INSON to'ldiradigan YAGONA qator ───────────────────────────────
# Google AI Studio'dan bepul key oling: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Quyidagilarni O'ZGARTIRMANG ────────────────────────────────────
# Bular docker-compose.yml dagi qiymatlarga MOS. Agent shu fayldan
# .env yasaydi, bu URL'lar shundoq ishlaydi. (faqat lokal dev uchun)

# App metadata bazasi (conversations, messages, saved_charts)
DATABASE_URL_APP=postgresql+psycopg://analytics:analytics_dev_pw@localhost:5432/app

# Sintetik biznes bazasi (seed yozadi)
DATABASE_URL_BIZ=postgresql+psycopg://analytics:analytics_dev_pw@localhost:5432/demo_biz

# Biznes bazasiga AGENT ulanadigan READ-ONLY ulanish
DATABASE_URL_BIZ_READONLY=postgresql+psycopg://readonly_user:readonly_pw@localhost:5432/demo_biz

# LLM modeli (almashtirsa bo'ladi)
LLM_MODEL=google-gla:gemini-2.5-flash

# ── Ixtiyoriy (default'lar kodda bor, tegmasa ham ishlaydi) ─────────
# Streamlit UI shu manzilga ulanadi
# API_URL=http://localhost:8000
# Seed "oxirgi oy" mantiqi shu sanaga nisbiy (bo'sh = seed ishlagan kun)
# ANCHOR_DATE=
